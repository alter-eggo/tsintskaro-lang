# Telegram Bot Tokens
TELEGRAM_BOT_TOKEN=your_production_bot_token
TELEGRAM_BOT_TOKEN_DEV=your_development_bot_token

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key

# Message threshold before auto-generating report (default: 100)
MESSAGE_THRESHOLD=100

# Environment (development/production)
NODE_ENV=development

# Postgres connection string for poll storage
# For managed Postgres with self-signed certs (e.g. DigitalOcean), append &uselibpqcompat=true
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require&uselibpqcompat=true

# Set to "true" to run scheduled polls in development (off by default)
POLL_ENABLE_IN_DEV=false
